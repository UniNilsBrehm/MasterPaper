\@writefile{los}{\contentsline {suppfigure}{\numberline {1}{\ignorespaces  (A) Spectrogram of an active pulse train from Carales astur. (B) Histogram of the pulse carrier frequency. (C) Intensity tuning curves for 20~kHz (black) and 85~kHz (gray). Red lines indicate a fit in the linear regime to determine intensity thresholds. (D) Power distribution of call series from Carales astur (dotted), Estigmene acrea (dashed) and several bat species (solid). (E) Frequency tuning curves for Estigmene acrea, based on either 50~ms (dashed) or 20~ms (solid) pure tone pulse duration. (F)requency tuning curves for Carales astur, based on 20~ms (solid) pure tone pulse duration. }}{27}{suppfigure.caption.36}\protected@file@percent }
\newlabel{suppfig:01}{{1}{27}{(A) Spectrogram of an active pulse train from Carales astur. (B) Histogram of the pulse carrier frequency. (C) Intensity tuning curves for 20~kHz (black) and 85~kHz (gray). Red lines indicate a fit in the linear regime to determine intensity thresholds. (D) Power distribution of call series from Carales astur (dotted), Estigmene acrea (dashed) and several bat species (solid). (E) Frequency tuning curves for Estigmene acrea, based on either 50~ms (dashed) or 20~ms (solid) pure tone pulse duration. (F)requency tuning curves for Carales astur, based on 20~ms (solid) pure tone pulse duration}{suppfigure.caption.36}{}}
\@writefile{los}{\contentsline {suppfigure}{\numberline {2}{\ignorespaces  (A) Example of an extracellular electrophysiological recording of auditory nerve signals in response to a rectangular amplitude modulation (top). Red dots indicate detected A1/A2 spikes, and blue crosses are spikes from the regular firing B neuron (non-auditory). (B) Probability density of inter spike intevals (ISI) for rectangular pulses with a pulse duration of 10~ms and a gap of 20~ms. Experimental data is shown in black and data from the Poisson spiking model in gray. (C) Probability density of the stimulus phase locking (data same as in B). (D) Mean vector strength over period. Black line is the experimental data. White line indicates the mean of all Poisson spiking models and gray is the 95th percentile of all Poisson spiking models. Values that are larger than that, are consider significant. s: stimulus period, f: firing rate. (E, F, G) Same as (B, C, D), but for artificial moth model pulses with a duration of 2~ms and gap of 20~ms. }}{28}{suppfigure.caption.37}\protected@file@percent }
\newlabel{suppfig:02}{{2}{28}{(A) Example of an extracellular electrophysiological recording of auditory nerve signals in response to a rectangular amplitude modulation (top). Red dots indicate detected A1/A2 spikes, and blue crosses are spikes from the regular firing B neuron (non-auditory). (B) Probability density of inter spike intevals (ISI) for rectangular pulses with a pulse duration of 10~ms and a gap of 20~ms. Experimental data is shown in black and data from the Poisson spiking model in gray. (C) Probability density of the stimulus phase locking (data same as in B). (D) Mean vector strength over period. Black line is the experimental data. White line indicates the mean of all Poisson spiking models and gray is the 95th percentile of all Poisson spiking models. Values that are larger than that, are consider significant. s: stimulus period, f: firing rate. (E, F, G) Same as (B, C, D), but for artificial moth model pulses with a duration of 2~ms and gap of 20~ms}{suppfigure.caption.37}{}}
\@writefile{los}{\contentsline {suppfigure}{\numberline {3}{\ignorespaces  (A) Spike raster plot (spike timing) from one recording session in response to a pure tone). (B) Firing rate over time (black line averaged over all trials, gray area indicates standard deviation). Dotted line shows the overall mean firing rate (averaged over time) with standard deviation. (B) Probability density of inter spike intevals (ISI) for pure tone. Experimental data is shown in black and data from the Poisson spiking model in gray. (C) Probability density of the stimulus phase locking (data same as in B). (D) Mean vector strength over period. Black line is the experimental data. White line indicates the mean of all Poisson spiking models and gray is the 95th percentile of all Poisson spiking models. Values that are larger than that, are consider significant. f: firing rate. }}{29}{suppfigure.caption.38}\protected@file@percent }
\newlabel{suppfig:03}{{3}{29}{(A) Spike raster plot (spike timing) from one recording session in response to a pure tone). (B) Firing rate over time (black line averaged over all trials, gray area indicates standard deviation). Dotted line shows the overall mean firing rate (averaged over time) with standard deviation. (B) Probability density of inter spike intevals (ISI) for pure tone. Experimental data is shown in black and data from the Poisson spiking model in gray. (C) Probability density of the stimulus phase locking (data same as in B). (D) Mean vector strength over period. Black line is the experimental data. White line indicates the mean of all Poisson spiking models and gray is the 95th percentile of all Poisson spiking models. Values that are larger than that, are consider significant. f: firing rate}{suppfigure.caption.38}{}}
\@writefile{los}{\contentsline {suppfigure}{\numberline {4}{\ignorespaces  Moth vs Bat call series. Percentage of moth classification (color coded) depending on spike train duration. The red line in each heatmap separates moth (M) from bat (B) call IDs. (A) Classification of call series based on a simple duration metric. (B)Classification of extended call series based on a simple duration metric. (C)Classification of call series based on a simple spike count. (D)Classification of extended call series based on a simple spike count metric. }}{30}{suppfigure.caption.39}\protected@file@percent }
\newlabel{suppfig:04}{{4}{30}{Moth vs Bat call series. Percentage of moth classification (color coded) depending on spike train duration. The red line in each heatmap separates moth (M) from bat (B) call IDs. (A) Classification of call series based on a simple duration metric. (B)Classification of extended call series based on a simple duration metric. (C)Classification of call series based on a simple spike count. (D)Classification of extended call series based on a simple spike count metric}{suppfigure.caption.39}{}}
\@writefile{los}{\contentsline {suppfigure}{\numberline {5}{\ignorespaces  First set of example recordings of auditory neurons A1/A2 in response to call series of different moth species. Each recording session has three traces (S, V and RP). S: Amplitude time course of the audio recording. V: Voltage trace of the extracellular electrophysiological recording. RP: Raster plot of spike times extracted from V. }}{31}{suppfigure.caption.40}\protected@file@percent }
\newlabel{suppfig:05}{{5}{31}{First set of example recordings of auditory neurons A1/A2 in response to call series of different moth species. Each recording session has three traces (S, V and RP). S: Amplitude time course of the audio recording. V: Voltage trace of the extracellular electrophysiological recording. RP: Raster plot of spike times extracted from V}{suppfigure.caption.40}{}}
\@writefile{los}{\contentsline {suppfigure}{\numberline {6}{\ignorespaces  Second set of example recordings of auditory neurons A1/A2 in response to call series of different moth species. Each recording session has three traces (S, V and RP). S: Amplitude time course of the audio recording. V: Voltage trace of the extracellular electrophysiological recording. RP: Raster plot of spike times extracted from V. }}{32}{suppfigure.caption.41}\protected@file@percent }
\newlabel{suppfig:06}{{6}{32}{Second set of example recordings of auditory neurons A1/A2 in response to call series of different moth species. Each recording session has three traces (S, V and RP). S: Amplitude time course of the audio recording. V: Voltage trace of the extracellular electrophysiological recording. RP: Raster plot of spike times extracted from V}{suppfigure.caption.41}{}}
\@writefile{los}{\contentsline {suppfigure}{\numberline {7}{\ignorespaces  Example recordings of auditory neurons A1/A2 in response to call series of different bat species. Each recording session has three traces (S, V and RP). S: Amplitude time course of the audio recording. V: Voltage trace of the extracellular electrophysiological recording. RP: Raster plot of spike times extracted from V. }}{33}{suppfigure.caption.42}\protected@file@percent }
\newlabel{suppfig:07}{{7}{33}{Example recordings of auditory neurons A1/A2 in response to call series of different bat species. Each recording session has three traces (S, V and RP). S: Amplitude time course of the audio recording. V: Voltage trace of the extracellular electrophysiological recording. RP: Raster plot of spike times extracted from V}{suppfigure.caption.42}{}}
